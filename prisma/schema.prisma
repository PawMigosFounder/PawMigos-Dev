generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ============================================================
// ENUMS
// ============================================================

enum UserRole {
  CONSUMER
  PROVIDER
  ADMIN
}

enum OnboardingIntent {
  HAS_PET
  PROVIDER
  EXPLORING
}

enum PetType {
  DOG
  CAT
  OTHER
}

enum PetSex {
  MALE
  FEMALE
}

enum AgeGroup {
  PUPPY_KITTEN  // 0-1 year
  YOUNG         // 1-3 years
  ADULT         // 3-7 years
  SENIOR        // 7+ years
}

enum WeightRange {
  SMALL   // < 10kg
  MEDIUM  // 10-25kg
  LARGE   // 25-45kg
  GIANT   // > 45kg
}

enum VaccinationStatus {
  UP_TO_DATE
  PARTIALLY_DONE
  NOT_VACCINATED
  UNKNOWN
}

enum Temperament {
  CALM
  FRIENDLY
  ENERGETIC
  ANXIOUS
  AGGRESSIVE
  SHY
}

enum FriendlinessLevel {
  VERY_FRIENDLY
  FRIENDLY
  NEUTRAL
  CAUTIOUS
  NOT_FRIENDLY
}

enum FoodType {
  DRY_KIBBLE
  WET_FOOD
  RAW
  HOME_COOKED
  MIXED
}

enum FeedingSchedule {
  ONCE_DAILY
  TWICE_DAILY
  THREE_TIMES_DAILY
  FREE_FEEDING
}

enum ExerciseNeeds {
  LOW
  MODERATE
  HIGH
  VERY_HIGH
}

enum ServiceCategory {
  GROOMING
  BOARDING
  TRAINING
  SITTING
  WALKING
  OTHER
}

enum ServiceType {
  HOME_VISIT     // Provider comes to consumer
  AT_PROVIDER    // Pet goes to provider
  OUTDOOR        // Walking, outdoor training
}

enum ProviderOnboardingState {
  DRAFT
  SUBMITTED
  PENDING_VERIFICATION
  VERIFIED
  FAILED
  ACTIVE
  SUSPENDED
}

enum VerificationStatus {
  DRAFT
  PENDING
  VERIFIED
  FAILED
}

enum BookingStatus {
  PENDING
  ACCEPTED
  REJECTED
  COMPLETED
  CANCELLED
  EXPIRED
}

enum PaymentStatus {
  PENDING
  PAID
  DISPUTED
}

enum PaymentMode {
  UPI
  CASH
  BANK_TRANSFER
}

enum CompatibilityOutcome {
  COMPATIBLE
  REVIEW_REQUIRED
  NOT_COMPATIBLE
}

enum NotificationType {
  BOOKING_REQUESTED
  BOOKING_ACCEPTED
  BOOKING_REJECTED
  BOOKING_CANCELLED
  BOOKING_AUTO_CANCELLED
  BOOKING_REMINDER
  BOOKING_COMPLETED
  VERIFICATION_OUTCOME
}

enum NotificationChannel {
  SMS
  IN_APP
}

enum AccommodationType {
  APARTMENT
  HOUSE
  VILLA
  FARM
  OTHER
}

enum AccommodationSize {
  SMALL
  MEDIUM
  LARGE
  EXTRA_LARGE
}

enum AdminActionType {
  PROVIDER_ACTIVATED
  PROVIDER_SUSPENDED
  PROVIDER_DEACTIVATED
  VERIFICATION_OVERRIDE
  BOOKING_CANCELLED
  USER_FLAGGED
  PROVIDER_FLAGGED
}

// ============================================================
// MODELS
// ============================================================

model User {
  id                   String            @id @default(cuid())
  phone                String            @unique
  name                 String?
  city                 String?
  profilePhoto         String?
  role                 UserRole          @default(CONSUMER)
  onboardingIntent     OnboardingIntent?
  onboardingCompleted  Boolean           @default(false)
  isActive             Boolean           @default(true)
  createdAt            DateTime          @default(now())
  updatedAt            DateTime          @updatedAt

  pets            Pet[]
  bookings        Booking[]        @relation("ConsumerBookings")
  reviews         Review[]
  communityPosts  CommunityPost[]
  notifications   Notification[]
  provider        Provider?
  adminAuditLogs  AdminAuditLog[]  @relation("AdminActor")

  @@index([phone])
  @@index([city])
}

model Pet {
  id                    String            @id @default(cuid())
  userId                String
  name                  String
  type                  PetType
  breed                 String?
  ageGroup              AgeGroup
  sex                   PetSex
  weightRange           WeightRange?
  photo                 String?
  neuteredOrSpayed      Boolean           @default(false)
  isActive              Boolean           @default(true)
  careProfileCompleted  Boolean           @default(false)
  createdAt             DateTime          @default(now())
  updatedAt             DateTime          @updatedAt

  user        User       @relation(fields: [userId], references: [id])
  careProfile PetCareProfile?
  bookings    Booking[]

  @@index([userId])
  @@index([userId, isActive])
}

model PetCareProfile {
  id        String @id @default(cuid())
  petId     String @unique

  // Health and vaccination
  vaccinationStatus    VaccinationStatus @default(UNKNOWN)
  vaccinationDetails   String?
  lastVaccinationDate  DateTime?
  rabiesVaccinated     Boolean           @default(false)
  dewormedStatus       Boolean           @default(false)
  fleaTickTreated      Boolean           @default(false)
  medicalConditions    String?
  medicationRequired   Boolean           @default(false)
  medicationInstructions String?
  allergies            String?
  emergencyContact     String?
  vetName              String?
  vetContact           String?

  // Reproductive and hygiene
  femaleInHeatCurrently Boolean  @default(false)
  pregnant              Boolean  @default(false)
  recentlyDelivered     Boolean  @default(false)
  markingBehavior       Boolean  @default(false)
  toiletTrained         Boolean  @default(true)

  // Food and feeding
  foodType                 FoodType?
  feedingSchedule          FeedingSchedule?
  dietaryRestrictions      String?
  foodAllergies            String?
  treatsAllowed            Boolean    @default(true)
  specialFeedingInstructions String?

  // Behavior and handling
  temperament          Temperament?
  friendlyWithDogs     FriendlinessLevel?
  friendlyWithCats     FriendlinessLevel?
  friendlyWithChildren FriendlinessLevel?
  biteHistory          Boolean           @default(false)
  aggressionHistory    Boolean           @default(false)
  separationAnxiety    Boolean           @default(false)
  crateTrained         Boolean           @default(false)
  leashTrained         Boolean           @default(false)
  escapeRisk           Boolean           @default(false)
  specialHandlingNotes String?

  // Care expectations
  walkingFrequency     String?
  exerciseNeeds        ExerciseNeeds?
  groomingNeeds        String?
  sleepHabits          String?
  comfortItems         String?
  emergencyInstructions String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  pet Pet @relation(fields: [petId], references: [id])
}

model Provider {
  id                     String                  @id @default(cuid())
  userId                 String                  @unique
  name                   String
  businessName           String?
  city                   String
  phone                  String
  profilePhoto           String?
  description            String?
  experience             String?
  mediaGallery           String[]                @default([])
  categories             ServiceCategory[]
  onboardingState        ProviderOnboardingState  @default(DRAFT)
  verificationStatus     VerificationStatus       @default(DRAFT)
  isActive               Boolean                  @default(false)
  hostingProfileCompleted Boolean                 @default(false)
  totalCompletedBookings  Int                     @default(0)
  averageRating          Float?
  reviewCount            Int                      @default(0)
  createdAt              DateTime                 @default(now())
  updatedAt              DateTime                 @updatedAt

  user                   User                     @relation(fields: [userId], references: [id])
  services               Service[]
  availability           Availability[]
  bookings               Booking[]                @relation("ProviderBookings")
  reviews                Review[]
  verificationRecords    VerificationRecord[]
  accommodationProfile   AccommodationProfile?
  hostingRestrictions    HostingRestrictions?

  @@index([city])
  @@index([city, isActive])
  @@index([verificationStatus])
}

model Service {
  id           String          @id @default(cuid())
  providerId   String
  category     ServiceCategory
  title        String
  description  String?
  price        Float
  serviceType  ServiceType
  isActive     Boolean         @default(true)
  createdAt    DateTime        @default(now())
  updatedAt    DateTime        @updatedAt

  provider Provider  @relation(fields: [providerId], references: [id])
  bookings Booking[]

  @@index([providerId])
  @@index([providerId, category])
}

model Availability {
  id          String   @id @default(cuid())
  providerId  String
  dayOfWeek   Int      // 0=Sunday, 6=Saturday
  startTime   String   // HH:mm format
  endTime     String   // HH:mm format
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  provider Provider @relation(fields: [providerId], references: [id])

  @@index([providerId])
  @@index([providerId, dayOfWeek])
}

model AccommodationProfile {
  id                    String            @id @default(cuid())
  providerId            String            @unique
  accommodationType     AccommodationType
  accommodationSize     AccommodationSize
  outdoorSpaceAvailable Boolean           @default(false)
  fencedProperty        Boolean           @default(false)
  numberOfExistingPets  Int               @default(0)
  existingPetTypes      String?
  childrenInHome        Boolean           @default(false)
  elderlyInHome         Boolean           @default(false)
  smokingInHome         Boolean           @default(false)
  vehicleAvailableForEmergency Boolean    @default(false)
  emergencyVetAccess    Boolean           @default(false)
  createdAt             DateTime          @default(now())
  updatedAt             DateTime          @updatedAt

  provider Provider @relation(fields: [providerId], references: [id])
}

model HostingRestrictions {
  id                         String      @id @default(cuid())
  providerId                 String      @unique
  acceptsDogs                Boolean     @default(true)
  acceptsCats                Boolean     @default(true)
  acceptsOtherPets           Boolean     @default(false)
  maxPetSizeAllowed          WeightRange @default(GIANT)
  maxNumberOfGuestPets       Int         @default(1)
  acceptsUnvaccinatedPets    Boolean     @default(false)
  acceptsPetsInHeat          Boolean     @default(false)
  acceptsUnneuteredUnspayed  Boolean     @default(true)
  acceptsSeniorPets          Boolean     @default(true)
  acceptsMedicationCases     Boolean     @default(false)
  acceptsSpecialNeedsPets    Boolean     @default(false)
  acceptsAggressiveReactive  Boolean     @default(false)
  acceptsPuppiesOrKittens    Boolean     @default(true)
  acceptsLargeBreeds         Boolean     @default(true)
  breedRestrictions          String?     // Comma-separated or JSON
  ageRestrictions            String?
  healthRestrictions         String?
  behaviorRestrictions       String?
  createdAt                  DateTime    @default(now())
  updatedAt                  DateTime    @updatedAt

  provider Provider @relation(fields: [providerId], references: [id])
}

model Booking {
  id              String         @id @default(cuid())
  userId          String
  providerId      String
  serviceId       String
  petId           String
  date            DateTime
  startTime       String         // HH:mm
  endTime         String?        // HH:mm
  status          BookingStatus  @default(PENDING)
  price           Float
  paymentStatus   PaymentStatus  @default(PENDING)
  paymentMode     PaymentMode?
  cancellationReason String?
  compatibilityResult CompatibilityOutcome?
  compatibilityNotes  String?
  providerResponseDeadline DateTime?
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt

  user     User     @relation("ConsumerBookings", fields: [userId], references: [id])
  provider Provider @relation("ProviderBookings", fields: [providerId], references: [id])
  service  Service  @relation(fields: [serviceId], references: [id])
  pet      Pet      @relation(fields: [petId], references: [id])
  review   Review?

  @@index([userId])
  @@index([providerId])
  @@index([providerId, status])
  @@index([providerId, date])
  @@index([status])
}

model Review {
  id          String   @id @default(cuid())
  bookingId   String   @unique
  userId      String
  providerId  String
  rating      Int      // 1-5
  reviewText  String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  booking  Booking  @relation(fields: [bookingId], references: [id])
  user     User     @relation(fields: [userId], references: [id])
  provider Provider @relation(fields: [providerId], references: [id])

  @@index([providerId])
  @@index([userId])
}

model CommunityPost {
  id        String   @id @default(cuid())
  userId    String
  content   String
  mediaUrl  String?
  likes     Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user     User              @relation(fields: [userId], references: [id])
  comments CommunityComment[]

  @@index([createdAt(sort: Desc)])
  @@index([userId])
}

model CommunityComment {
  id        String   @id @default(cuid())
  postId    String
  userId    String
  content   String
  createdAt DateTime @default(now())

  post CommunityPost @relation(fields: [postId], references: [id], onDelete: Cascade)

  @@index([postId])
}

model VerificationRecord {
  id                 String             @id @default(cuid())
  providerId         String
  vendorRefId        String?
  verificationStatus VerificationStatus @default(DRAFT)
  maskedIdentifier   String?
  faceMatchScore     Float?
  attemptNumber      Int                @default(1)
  failureReason      String?
  completedAt        DateTime?
  createdAt          DateTime           @default(now())
  updatedAt          DateTime           @updatedAt

  provider Provider @relation(fields: [providerId], references: [id])

  @@index([providerId])
}

model Notification {
  id        String              @id @default(cuid())
  userId    String
  type      NotificationType
  channel   NotificationChannel @default(IN_APP)
  title     String
  message   String
  data      String?             // JSON metadata
  isRead    Boolean             @default(false)
  sentAt    DateTime?
  failedAt  DateTime?
  createdAt DateTime            @default(now())

  user User @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([userId, isRead])
  @@index([createdAt(sort: Desc)])
}

model OtpRecord {
  id        String   @id @default(cuid())
  phone     String
  code      String
  expiresAt DateTime
  verified  Boolean  @default(false)
  attempts  Int      @default(0)
  createdAt DateTime @default(now())

  @@index([phone, code])
  @@index([phone, createdAt(sort: Desc)])
}

model AdminAuditLog {
  id           String          @id @default(cuid())
  adminUserId  String
  actionType   AdminActionType
  targetEntity String
  targetId     String
  details      String?
  createdAt    DateTime        @default(now())

  adminUser User @relation("AdminActor", fields: [adminUserId], references: [id])

  @@index([adminUserId])
  @@index([targetEntity, targetId])
  @@index([createdAt(sort: Desc)])
}
